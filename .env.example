# ============================================================
# .env.example – health-micro-ai
# Sao chép file này thành .env và điền giá trị thực tế
# cp .env.example .env
# ============================================================

# ── JWT Secret (QUAN TRỌNG: đổi sang giá trị ngẫu nhiên trong production) ──
JWT_SECRET=health-micro-ai-jwt-secret-key-2024-change-in-production

# ── Database PostgreSQL ──────────────────────────────────────────────────────
DB_PASSWORD=postgres

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=health123

# ── Gemini API (LLM cho Clinical Advisory Service) ────────────────────────────
# Lấy API key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Embedding Model (FAISS) ──────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=/app/faiss_data

# ── Healthcare Service URLs (internal Docker network) ─────────────────────────
# Không cần thay đổi nếu dùng docker-compose
AUTH_SERVICE_URL=http://auth-service:8000
PATIENT_SERVICE_URL=http://patient-service:8000
PHARMACY_SERVICE_URL=http://pharmacy-service:8000
MEDICAL_CATALOG_SERVICE_URL=http://medical-catalog-service:8000
PRESCRIPTION_SERVICE_URL=http://prescription-service:8000
DISPENSING_SERVICE_URL=http://dispensing-service:8000
MEDICAL_REVIEW_SERVICE_URL=http://medical-review-service:8000
CLINICAL_ADVISORY_SERVICE_URL=http://clinical-advisory-service:8000
TREATMENT_REC_SERVICE_URL=http://treatment-recommender-service:8000

# ── Django Settings ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=health-micro-ai-django-secret-key-change-in-production
DEBUG=True
